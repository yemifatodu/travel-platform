# Supabase
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# APIs (plug in as you build)
FLIGHT_API_KEY=your_amadeus_or_skyscanner_key
HOTEL_API_KEY=your_booking_com_or_hotels_api_key
WEATHER_API_KEY=your_openweather_key
CURRENCY_API_KEY=your_exchangerate_key
MAPS_API_KEY=your_google_maps_key

# Payments
STRIPE_SECRET_KEY=your_stripe_secret
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=your_stripe_public

# Email
RESEND_API_KEY=your_resend_key

# AI
OPENAI_API_KEY=your_openai_key

# ── AI FEATURES ──────────────────────────
# Get your key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-key-here
# Used by:
# /api/ai-itinerary     → AI Trip Planner (GPT-4)
# /api/price-prediction → Price Intelligence (GPT-4)
# /api/recommendations  → Destination Finder (GPT-4)
# /api/budget-estimate  → Budget Calculator (GPT-4)
