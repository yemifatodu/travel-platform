"use client";

import { useState, useEffect, Suspense } from "react";
import { useSearchParams } from "next/navigation";
import Link from "next/link";

interface Plan {
  id: string;
  title: string;
  country_code: string;
  country_name: string;
  data_amount: string;
  validity_days: number;
  retail_price: number;
  currency: string;
  covered_countries?: string[];
}

// 🔧 MOCK PLANS FOR DEVELOPMENT (matches your Edge Function)
const MOCK_PLANS: Record<string, Plan> = {
  "mock-us": { 
    id: "mock-us", 
    title: "USA Travel eSIM", 
    country_code: "US", 
    country_name: "United States",
    data_amount: "5GB", 
    validity_days: 30, 
    retail_price: 19.99, 
    currency: "USD",
    covered_countries: ["US"]
  },
  "mock-uk": { 
    id: "mock-uk", 
    title: "UK Explorer eSIM", 
    country_code: "GB", 
    country_name: "United Kingdom",
    data_amount: "3GB", 
    validity_days: 14, 
    retail_price: 12.99, 
    currency: "USD",
    covered_countries: ["GB"]
  },
  "mock-jp": { 
    id: "mock-jp", 
    title: "Japan Data Pass", 
    country_code: "JP", 
    country_name: "Japan",
    data_amount: "10GB", 
    validity_days: 15, 
    retail_price: 24.99, 
    currency: "USD",
    covered_countries: ["JP"]
  },
};

// Component that uses useSearchParams
function CheckoutContent() {
  const searchParams = useSearchParams();
  const planId = searchParams.get("plan_id");
  
  const [plan, setPlan] = useState<Plan | null>(null);
  const [loading, setLoading] = useState(true);
  const [processing, setProcessing] = useState(false);
  const [customerInfo, setCustomerInfo] = useState({
    name: "",
    email: "",
    phone: "",
  });

  useEffect(() => {
    if (planId) {
      fetchPlan(planId);
    }
  }, [planId]);

  const fetchPlan = async (id: string) => {
    try {
      // 🔧 Use mock data for development IDs
      if (id.startsWith("mock-") && MOCK_PLANS[id]) {
        setPlan(MOCK_PLANS[id]);
        setLoading(false);
        return;
      }

      // ✅ FIXED: Use query parameter (?id=) instead of path parameter (/id)
      // Your API route expects: /api/esim/plans?id=UUID
      const res = await fetch(`/api/esim/plans?id=${id}`);
      const data = await res.json();
      
      if (data.success) {
        setPlan(data.data);
      } else {
        console.warn("Plan fetch failed:", data.error);
      }
    } catch (error) {
      console.error("Error fetching plan:", error);
    } finally {
      setLoading(false);
    }
  };

  const handleSubmit = async (e: React.FormEvent) => {
    e.preventDefault();
    
    if (!customerInfo.name || !customerInfo.email) {
      alert("Please fill in your name and email");
      return;
    }

    setProcessing(true);

    try {
      const response = await fetch("/api/esim/orders", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({
          plan_id: plan?.id,
          customer_name: customerInfo.name,
          customer_email: customerInfo.email,
          customer_phone: customerInfo.phone,
        }),
      });

      const result = await response.json();
      
      if (result.success) {
        window.location.href = `/esim/order-confirmation?id=${result.data.id}`;
      } else {
        throw new Error(result.error || "Order failed");
      }
    } catch (error) {
      console.error("Order error:", error);
      alert("Failed to create order. Please try again.");
      setProcessing(false);
    }
  };

  if (loading) {
    return (
      <div className="checkout-loader">
        <div className="spinner"></div>
        <p>Loading checkout...</p>
        <style>{`
          .checkout-loader { min-height: 100vh; background: #080807; display: flex; align-items: center; justify-content: center; flex-direction: column; color: #F5EFE4; }
          .spinner { width: 40px; height: 40px; border: 2px solid rgba(200,169,110,0.2); border-top-color: #C8A96E; border-radius: 50%; animation: spin 0.8s linear infinite; margin: 0 auto 16px; }
          @keyframes spin { to { transform: rotate(360deg); } }
        `}</style>
      </div>
    );
  }

  if (!plan) {
    return (
      <div className="checkout-error" style={{ minHeight: "100vh", background: "#080807", display: "flex", alignItems: "center", justifyContent: "center", flexDirection: "column", color: "#F5EFE4" }}>
        <p style={{ marginBottom: 20 }}>Plan not found</p>
        <Link href="/esim" style={{ color: "#C8A96E", textDecoration: "none" }}>← Back to Plans</Link>
      </div>
    );
  }

  return (
    <div className="checkout-container">
      <style>{`
        :root {
          --bg: #080807;
          --card-bg: #121210;
          --gold: #C8A96E;
          --gold-dim: rgba(200,169,110,0.2);
          --text: #F5EFE4;
          --text-dim: rgba(245,239,228,0.7);
          --border: rgba(200,169,110,0.15);
          --radius: 12px;
        }
        .checkout-container { min-height: 100vh; background: var(--bg); padding: 60px 20px; }
        .checkout-card { max-width: 500px; margin: 0 auto; background: var(--card-bg); border: 1px solid var(--border); border-radius: var(--radius); padding: 32px; }
        .checkout-title { font-size: 1.8rem; color: var(--gold); text-align: center; margin-bottom: 24px; }
        .order-summary { text-align: center; padding: 20px; background: rgba(0,0,0,0.3); border-radius: var(--radius); margin-bottom: 24px; }
        .order-summary h3 { margin: 0 0 8px; color: var(--gold); }
        .order-price { font-size: 1.6rem; color: var(--gold); margin: 12px 0 0; }
        .form-group { margin-bottom: 16px; }
        .form-group label { display: block; margin-bottom: 6px; color: var(--text-dim); font-size: 0.85rem; }
        .form-input { width: 100%; padding: 12px 16px; background: var(--bg); border: 1px solid var(--gold-dim); border-radius: 8px; color: var(--text); outline: none; transition: 0.2s; }
        .form-input:focus { border-color: var(--gold); box-shadow: 0 0 0 3px rgba(200,169,110,0.15); }
        .submit-btn { width: 100%; padding: 14px; background: var(--gold); border: none; border-radius: 8px; color: var(--bg); font-weight: 600; font-size: 1rem; cursor: pointer; transition: 0.2s; margin-top: 8px; }
        .submit-btn:hover { background: #b8965a; transform: translateY(-1px); }
        .submit-btn:disabled { opacity: 0.6; cursor: not-allowed; transform: none; }
        .back-link { display: block; text-align: center; margin-top: 20px; color: var(--text-dim); text-decoration: none; }
        .back-link:hover { color: var(--gold); }
      `}</style>

      <div className="checkout-card">
        <h1 className="checkout-title">Complete Purchase</h1>

        <div className="order-summary">
          <h3>{plan.data_amount}</h3>
          <p>{plan.validity_days} days • {plan.country_name}</p>
          {plan.covered_countries && (
            <p style={{ fontSize: "0.75rem", color: "var(--text-dim)" }}>
              📍 Covers: {plan.covered_countries.slice(0, 3).join(", ")}
              {plan.covered_countries.length > 3 ? "..." : ""}
            </p>
          )}
          <div className="order-price">${plan.retail_price} {plan.currency}</div>
        </div>

        <form onSubmit={handleSubmit}>
          <div className="form-group">
            <label>Full Name *</label>
            <input
              type="text"
              className="form-input"
              value={customerInfo.name}
              onChange={(e) => setCustomerInfo({ ...customerInfo, name: e.target.value })}
              required
            />
          </div>
          <div className="form-group">
            <label>Email Address *</label>
            <input
              type="email"
              className="form-input"
              value={customerInfo.email}
              onChange={(e) => setCustomerInfo({ ...customerInfo, email: e.target.value })}
              required
            />
          </div>
          <div className="form-group">
            <label>Phone Number (optional)</label>
            <input
              type="tel"
              className="form-input"
              value={customerInfo.phone}
              onChange={(e) => setCustomerInfo({ ...customerInfo, phone: e.target.value })}
            />
          </div>

          <button type="submit" className="submit-btn" disabled={processing}>
            {processing ? "PROCESSING..." : `CONFIRM ORDER - $${plan.retail_price} ${plan.currency}`}
          </button>
        </form>

        <Link href="/esim" className="back-link">
          ← Back to Plans
        </Link>
      </div>
    </div>
  );
}

// Main page component with Suspense boundary
export default function CheckoutPage() {
  return (
    <Suspense fallback={<div style={{ minHeight: "100vh", background: "#080807", display: "flex", alignItems: "center", justifyContent: "center", color: "#F5EFE4" }}>Loading checkout...</div>}>
      <CheckoutContent />
    </Suspense>
  );
}